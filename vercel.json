{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/admin/verify", "destination": "/api/admin/verify" },
    { "source": "/api/send-invitation", "destination": "/api/send-invitation" },
    { "source": "/api/rsvps", "destination": "/api/rsvps" },
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}