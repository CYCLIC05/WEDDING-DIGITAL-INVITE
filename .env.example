# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: Your Supabase Project API URL (e.g. https://your-project.supabase.co)
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: Required for admin-level operations (bypass RLS in server.ts)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# RESEND_API_KEY: Standard api key from resend.com for sending transactional gatepass emails
RESEND_API_KEY="re_123456789"

# SYSTEM_ADMIN_PASSCODE: The passcode required to access the Groom's admin dashboard
SYSTEM_ADMIN_PASSCODE="ChidiAdanna2026"
