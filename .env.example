# ============================================================================
# Environment Variables Blueprint: Royal Christian Wedding RSVP System
# File: .env.example
# ============================================================================

# GEMINI_API_KEY: Standard API key for Gemini models inside server-side proxies.
# AI Studio automatically injects this at runtime with values from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The self-referential URL where this application is hosted.
# Used for CORS mapping, redirect headers, and transactional message links.
APP_URL="https://your-app-subdomain.up.railway.app"

# ----------------------------------------------------------------------------
# BACKEND-ONLY SECURED DATA SERVICES (SUPABASE & EMAIL)
# ----------------------------------------------------------------------------
# SUPABASE_URL: Your Supabase Project's API URL (e.g., https://yourproject.supabase.co)
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: High-privilege role key to bypass client RLS policies safely.
# Keep this strictly secret! Never expose to client bundles or browser interfaces.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# RESEND_API_KEY: Secure token from resend.com for sending real transactional gatepass emails.
RESEND_API_KEY="re_123456789"

# SYSTEM_ADMIN_PASSCODE: The cryptographic secret token required to unlock Groom's Roster.
SYSTEM_ADMIN_PASSCODE="ChidiAdanna2026"

# ----------------------------------------------------------------------------
# CLIENT-ONLY DATA SERVICES (VITE EXTENSIONS)
# ----------------------------------------------------------------------------
# VITE_SUPABASE_URL: Public url allowed inside Vite bundling targets.
VITE_SUPABASE_URL="https://your-project.supabase.co"

# VITE_SUPABASE_ANON_KEY: Public key allowed inside client browser code for safe standard ops.
VITE_SUPABASE_ANON_KEY="your-supabase-public-anon-key"
